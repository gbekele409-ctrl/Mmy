# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/aviator

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Seed admin (used only by scripts/createAdmin.js)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# HTTPS (production - see server.js notes)
# When behind a reverse proxy (nginx/Caddy) doing TLS termination,
# leave these unset and set TRUST_PROXY=1 instead.
TRUST_PROXY=0

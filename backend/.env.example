# Server
PORT=5000
NODE_ENV=production
CLIENT_ORIGIN=https://mmy-1c4m.vercel.app

# Database - Supabase Postgres
# In Supabase: Project Settings -> Database -> Connection string -> "Connection pooling"
# (use the pooled/6543 URI for a long-running server like Railway; the
# direct/5432 URI also works but pooling is recommended)
DATABASE_URL=postgresql://postgres:Gutu%401234Gua@db.udohnelsljaprlwqjose.supabase.co:5432/postgres
# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Seed admin (used only by scripts/createAdmin.js)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# Railway terminates TLS for you - trust its proxy so req.ip / rate limiting work correctly
TRUST_PROXY=1
